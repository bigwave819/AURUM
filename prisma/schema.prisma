// ============================================================
//  AURUM — Prisma Schema
//  DB: PostgreSQL via NeonDB (serverless)
//  Auth: Clerk (no User table — clerkUserId string references)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum WatchCategory {
  DRESS
  SPORT
  LIMITED
  COMPLICATIONS
  HERITAGE
  MODERN_CLASSICS
  RARE_FINDS
  ACCESSORIES
}

enum MovementType {
  AUTOMATIC
  MANUAL
  QUARTZ
  GRAND_COMPLICATION
}

enum WatchStatus {
  ACTIVE      // listed on public catalog
  ARCHIVED    // hidden from storefront, kept in records
  LOW_STOCK   // stock <= lowStockThreshold
  OUT_OF_STOCK
}

enum OrderStatus {
  ORDERED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum CustomerTier {
  STANDARD
  COLLECTOR    // repeat buyer
  ELITE        // high-value, VIP treatment
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique           // "Patek Philippe", "Audemars Piguet"
  slug        String   @unique           // "patek-philippe"
  logoUrl     String?                    // optional brand logo for storefront
  description String?
  origin      String?                    // "Geneva, Switzerland"
  foundedYear Int?

  watches     Watch[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Watch {
  id                 String        @id @default(cuid())
  slug               String        @unique  // for public URL: /watch/[slug]
  name               String                 // "Royal Oak 'Jumbo' Extra-Thin"
  referenceNumber    String        @unique  // "16202ST.OO.1240S"
  brandId            String
  brand              Brand         @relation(fields: [brandId], references: [id])
  category           WatchCategory

  // — Movement & Materials —
  movement           MovementType
  caseMaterial       String                 // "Stainless Steel", "18k Rose Gold", "Platinum"
  caseDiameterMm     Float                  // 39, 42 etc.
  waterResistanceM   Int?                   // metres — 50, 100, 300
  powerReserveHrs    Int?                   // 72, 48 etc.
  calibre            String?                // "Calibre A.88 Auto", "Calibre 7121"
  crystal            String?                // "Sapphire, double-domed"
  braceletMaterial   String?                // "Alligator leather", "Oyster bracelet"

  // — Commercial Details panel —
  priceUsd           Decimal       @db.Decimal(12, 2)
  stock              Int           @default(0)
  lowStockThreshold  Int           @default(2)  // triggers LOW_STOCK status + dashboard alert
  status             WatchStatus   @default(ACTIVE)
  isPublic           Boolean       @default(true)  // "Listed on Public Catalog" toggle

  // — Content —
  description        String?       @db.Text
  shortDescription   String?       // shown on collection card hover
  collectionName     String?       // "Heritage Collection", "Classic Series"

  // — Relations —
  tags               WatchTag[]
  images             WatchImage[]
  orderItems         OrderItem[]

  // — Timestamps —
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([brandId])
  @@index([category])
  @@index([status])
  @@index([slug])
  @@index([priceUsd])
}

// ============================================================
//  WATCH IMAGE
//  Seen in: Product page (main + 4 thumbnails), Edit watch upload zone
// ============================================================

model WatchImage {
  id          String   @id @default(cuid())
  watchId     String
  watch       Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)

  url         String   // Cloudinary URL
  publicId    String   // Cloudinary public_id for deletion
  altText     String?
  position    Int      @default(0)  // 0 = primary image shown in inventory + hero
  isPrimary   Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([watchId])
  @@index([position])
}

// ============================================================
//  WATCH TAG
//  Seen in: Edit Watch form — chip tags ("Iconic Design", "New Release", "Limited")
// ============================================================

model WatchTag {
  id       String  @id @default(cuid())
  watchId  String
  watch    Watch   @relation(fields: [watchId], references: [id], onDelete: Cascade)
  label    String  // "Iconic Design", "New Release", "Limited"

  @@unique([watchId, label])
  @@index([watchId])
}

// ============================================================
//  CUSTOMER
//  Seen in: Orders table (Customer column), Customers nav item,
//           Dashboard (New Customers KPI)
//  Clerk manages auth — we store profile + purchase history only
// ============================================================

model Customer {
  id           String       @id @default(cuid())
  clerkUserId  String       @unique  // links to Clerk user

  // — Profile —
  firstName    String
  lastName     String
  email        String       @unique
  phone        String?
  avatarUrl    String?      // Clerk profile photo or Cloudinary
  initials     String       // computed: "EK" for Elias Kaelin — shown in order rows

  // — Tier & Status —
  tier         CustomerTier @default(STANDARD)
  isActive     Boolean      @default(true)

  // — Address (shipping) —
  addressLine1 String?
  addressLine2 String?
  city         String?
  country      String?
  postalCode   String?

  // — Relations —
  orders       Order[]

  // — Timestamps —
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([email])
  @@index([clerkUserId])
  @@index([createdAt])  // for "New Customers" KPI — filter by month
}

// ============================================================
//  ORDER
//  Seen in: Dashboard recent transactions table, Orders page
//  Fields: #AU-9021, customer, model, price, status, actions
// ============================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique  // "AU-9021" — shown in tables

  // — Customer —
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])

  // — Financials —
  subtotalUsd     Decimal     @db.Decimal(12, 2)
  discountUsd     Decimal     @db.Decimal(12, 2) @default(0)
  totalUsd        Decimal     @db.Decimal(12, 2)  // shown in orders table as $32,500

  // — Status —
  status          OrderStatus @default(ORDERED)

  // — Shipping —
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // — Notes —
  internalNotes   String?     @db.Text  // admin notes, not shown to customer

  // — Relations —
  items           OrderItem[]

  // — Timestamps —
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])  // for date-range filter on Orders page
  @@index([orderNumber])
}

// ============================================================
//  ORDER ITEM
//  One order can have multiple watches (rare but possible)
//  Snapshot price at time of purchase — never changes even if watch price updates
// ============================================================

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  watchId       String
  watch         Watch    @relation(fields: [watchId], references: [id])

  // — Snapshot at time of sale —
  watchName     String   // denormalised — preserved if watch is renamed/deleted
  watchBrand    String
  watchRefNo    String
  priceUsd      Decimal  @db.Decimal(12, 2)  // price locked at purchase
  quantity      Int      @default(1)

  createdAt     DateTime @default(now())

  @@index([orderId])
  @@index([watchId])
}

// ============================================================
//  NEWSLETTER SUBSCRIBER
//  Seen in: Homepage + Collection page footer newsletter form
// ============================================================

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())

  @@index([email])
}

// ============================================================
//  ADMIN ACTIVITY LOG
//  Tracks who did what in the management suite — good practice
//  for a luxury goods platform with high-value inventory
// ============================================================

model ActivityLog {
  id           String   @id @default(cuid())
  clerkUserId  String                        // which admin performed the action
  action       String                        // "WATCH_CREATED", "ORDER_STATUS_UPDATED"
  entityType   String                        // "Watch", "Order", "Customer"
  entityId     String                        // the affected record's id
  metadata     Json?                         // before/after values, extra context
  createdAt    DateTime @default(now())

  @@index([clerkUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================
//  STORE SETTINGS
//  Seen in: Settings page — Store Identity + Regional Settings
//  Single-row table (id = "global")
// ============================================================

model StoreSettings {
  id           String   @id @default("global")
  storeName    String   @default("AURUM LUXURY HOROLOGY")
  publicEmail  String   @default("concierge@aurum.com")
  timezone     String   @default("Europe/Zurich")
  currency     String   @default("USD")          // "CHF", "USD", "EUR"
  unitSystem   String   @default("METRIC")        // "METRIC" | "IMPERIAL"
  updatedAt    DateTime @updatedAt
}
